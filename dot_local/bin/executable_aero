#!/bin/bash

set -euo pipefail

AGENTS=(
  com.nikitabobko.aerospace
  com.felixkratz.sketchybar.aero
  com.janky.borders.aero
  com.aero.helper
  com.aero.aeroswitch
)

PROCS=(AeroSpace sketchybar borders aerospace-helper aeroswitch)

AEROSPACE_BIN="/Applications/AeroSpace.app/Contents/MacOS/AeroSpace"
SKETCHYBAR_BIN="/opt/homebrew/bin/sketchybar"

INSTALL_DEPS=0

usage() {
  echo "Usage: $(basename "$0") [--install-deps] {start|stop|restart|status}"
  exit 1
}

prompt_install() {
  local name="$1"
  shift
  local cmds=("$@")

  echo "$name not found."
  if [[ $INSTALL_DEPS -eq 1 ]]; then
    echo "Installing $name..."
    for cmd in "${cmds[@]}"; do eval "$cmd"; done
    return 0
  fi

  read -rp "Install $name? [y/N] " answer
  if [[ "$answer" == [yY] ]]; then
    for cmd in "${cmds[@]}"; do eval "$cmd"; done
    return 0
  fi
  return 1
}

check_deps() {
  local missing=0
  if [[ ! -x "$AEROSPACE_BIN" ]]; then
    prompt_install "AeroSpace" "brew install --cask nikitabobko/tap/aerospace" || missing=1
  fi
  if [[ ! -x "$SKETCHYBAR_BIN" ]]; then
    prompt_install "sketchybar" "brew tap FelixKratz/formulae" "brew install sketchybar" || missing=1
  fi
  if ! command -v borders &>/dev/null; then
    prompt_install "borders" "brew tap FelixKratz/formulae" "brew install borders" || missing=1
  fi
  if ! brew list --cask font-sketchybar-app-font &>/dev/null; then
    prompt_install "sketchybar app font" "brew install --cask font-sketchybar-app-font" || missing=1
  fi
  if [[ $missing -eq 1 ]]; then
    exit 1
  fi
}

force_kill() {
  for proc in "${PROCS[@]}"; do
    pkill -9 -x "$proc" 2>/dev/null || true
  done
}

do_stop() {
  for agent in "${AGENTS[@]}"; do
    launchctl bootout "gui/$(id -u)/$agent" 2>/dev/null || true
    launchctl disable "gui/$(id -u)/$agent" 2>/dev/null || true
  done
  sleep 1
  force_kill
  rm -f /tmp/aerospace-helper.sock
  echo "Stopped and disabled all agents."
}

do_start() {
  for agent in "${AGENTS[@]}"; do
    launchctl enable "gui/$(id -u)/$agent" 2>/dev/null || true
    launchctl bootstrap "gui/$(id -u)" "$HOME/Library/LaunchAgents/${agent}.plist" 2>/dev/null || true
  done
  # Wait for helper socket, then trigger initial workspace state
  (
    for i in {1..10}; do
      [ -S /tmp/aerospace-helper.sock ] && break
      sleep 0.5
    done
    aero-notify workspace_changed
  ) &
  echo "Enabled and started all agents."
}

do_restart() {
  do_stop
  sleep 1
  do_start
}

do_status() {
  for agent in "${AGENTS[@]}"; do
    echo -n "$agent: "
    if launchctl print "gui/$(id -u)/$agent" &>/dev/null; then
      echo "loaded"
    else
      echo "not loaded"
    fi
  done
  echo ""
  for proc in "${PROCS[@]}"; do
    echo -n "$proc: "
    if pgrep -x "$proc" >/dev/null; then
      echo "running (pid $(pgrep -x "$proc" | tr '\n' ' '))"
    else
      echo "not running"
    fi
  done
}

while [[ $# -gt 0 && "$1" == --* ]]; do
  case "$1" in
    --install-deps) INSTALL_DEPS=1; shift ;;
    *) usage ;;
  esac
done

[[ $# -eq 1 ]] || usage

case "$1" in
  start)   check_deps; do_start ;;
  stop)    do_stop ;;
  restart) check_deps; do_restart ;;
  status)  do_status ;;
  *)       usage ;;
esac
