{
  "$schema": "https://komorebi-for-mac.lgug2z.com/komorebi.bar.0.1.0.schema.json",
  "monitor": {
    "index": 1
  },
  "font_family": "SF Pro",
  "font_size": 14,
  "transparency_alpha": 0,
  "height": 30,
  "theme": {
    "palette": "Catppuccin",
    "name": "Mocha",
    "accent": "Lavender"
  },
  "left_widgets": [],
  "right_widgets": [],
  "center_widgets": [
    {
      "Komorebi": {
        "workspaces": {
          "enable": true,
          "hide_empty_workspaces": false
        },
        "focused_container": {
          "enable": true,
          "show_icon": true
        }
      }
    }
  ]
}
