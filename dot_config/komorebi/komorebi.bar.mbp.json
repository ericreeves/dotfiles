{
  "$schema": "https://komorebi-for-mac.lgug2z.com/komorebi.bar.0.1.0.schema.json",
  "monitor": {
    "index": 1
  },
  "font_family": "SF Pro",
  "font_size": 14,
  "transparency_alpha": 0,
  "height": 40,
  "theme": {
    "palette": "Catppuccin",
    "name": "Mocha",
    "accent": "Lavender"
  },
  "left_widgets": [
    {
      "Komorebi": {
        "layout": {
          "enable": true
        },
        "workspaces": {
          "enable": true,
          "hide_empty_workspaces": false
        },
        "focused_container": {
          "enable": true,
          "show_icon": true
        }
      }
    }
  ],
  "right_widgets": [
    {
      "Update": {
        "enable": true
      }
    },
    {
      "Storage": {
        "enable": false
      }
    },
    {
      "Cpu": {
        "enable": true
      }
    },
    {
      "Memory": {
        "enable": true
      }
    },
    {
      "Network": {
        "enable": true,
        "show_activity": true,
        "show_total_activity": false
      }
    },
    {
      "Date": {
        "enable": true,
        "format": "YearMonthDate"
      }
    },
    {
      "Time": {
        "enable": true,
        "format": "TwentyFourHour"
      }
    }
  ],
  "center_widgets": []
}
