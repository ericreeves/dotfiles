{
  "$schema": "$HOME/.config/komorebi/schema.json",
  "app_specific_configuration_path": [
    "/Users/eric/.config/komorebi/applications.json"
  ],
  "bar_configurations": [
    "$HOME/.config/komorebi/komorebi.bar.1.json",
    "$HOME/.config/komorebi/komorebi.bar.2.json"
  ],
  "window_hiding_behaviour": "Cloak",
  "cross_monitor_move_behaviour": "Insert",
  "cross_boundary_behaviour": "Workspace",
  "transparency": false,
  "animation": {
    "enabled": false,
    "duration": 500,
    "fps": 120,
    "style": "EaseInOutExpo"
  },
  "display_index_preferences": {
    "0": "H1AK500000",
    "1": "4251086178"
  },
  "default_workspace_padding": 15,
  "default_container_padding": 15,
  "border_style": "System",
  "border_width": 5,
  "border": true,
  "border_offset": -4,
  "border_radius": 20,
  "theme": {
    "name": "Mocha",
    "palette": "Catppuccin",
    "accent": "Lavender",
    "bar_accent": "Lavender",
    "unfocused_border": "Crust",
    "unfocused_locked_border": "Pink",
    "floating_border": "Green",
    "single_border": "Lavender",
    "stack_border": "Green",
    "stackbar_background": "Crust",
    "stackbar_focused_text": "Lavender",
    "stackbar_unfocused_text": "Surface0"
  },
  "stackbar": {
    "height": 40,
    "mode": "OnStack",
    "label": "Title",
    "tabs": {
      "width": 400,
      "font_family": "SF Pro",
      "font_size": 18
    }
  },
  "monitors": [
    {
      "window_based_work_area_offset_limit": 1,
      "window_based_work_area_offset": {
        "top": 0,
        "left": 1280,
        "right": 2560,
        "bottom": 0
      },
      "workspaces": [
        {
          "name": "1",
          "layout": "UltrawideVerticalStack",
          "layout_options": {
            "column_ratios": [
              0.5,
              0.25
            ],
            "row_ratios": [
              0.5
            ]
          },
          "initial_workspace_rules": [
            {
              "id": "vivaldi.exe",
              "kind": "Exe",
              "matching_strategy": "Equals"
            },
            {
              "id": "wezterm-gui.exe",
              "kind": "Exe",
              "matching_strategy": "Equals"
            }
          ]
        },
        {
          "name": "2",
          "layout": "UltrawideVerticalStack",
          "layout_options": {
            "column_ratios": [
              0.5,
              0.25
            ],
            "row_ratios": [
              0.5
            ]
          },
          "initial_workspace_rules": [
            {
              "id": "Chrome.exe",
              "kind": "Exe",
              "matching_strategy": "Equals"
            }
          ]
        },
        {
          "name": "3",
          "layout": "UltrawideVerticalStack",
          "layout_options": {
            "column_ratios": [
              0.5,
              0.25
            ],
            "row_ratios": [
              0.5
            ]
          }
        },
        {
          "name": "4",
          "layout": "UltrawideVerticalStack",
          "layout_options": {
            "column_ratios": [
              0.5,
              0.25
            ],
            "row_ratios": [
              0.5
            ]
          },
          "initial_workspace_rules": [
            {
              "id": "Spotify.exe",
              "kind": "Exe",
              "matching_strategy": "Equals"
            }
          ]
        },
        {
          "name": "5",
          "layout": "UltrawideVerticalStack",
          "layout_options": {
            "column_ratios": [
              0.5,
              0.25
            ],
            "row_ratios": [
              0.5
            ]
          },
          "initial_workspace_rules": [
            {
              "id": "reaper.exe",
              "kind": "Exe",
              "matching_strategy": "Equals"
            }
          ],
          "intial_workspace_rules": [
            {
              "kind": "Path",
              "id": "C:\\Program Files (x86)\\Steam",
              "matching_strategy": "StartsWith"
            },
            {
              "kind": "Path",
              "id": "G:\\Games",
              "matching_strategy": "StartsWith"
            }
          ]
        }
      ]
    },
    {
      "workspaces": [
        {
          "name": "1",
          "layout": "BSP"
        },
        {
          "name": "2",
          "layout": "BSP"
        },
        {
          "name": "3",
          "layout": "BSP"
        },
        {
          "name": "4",
          "layout": "BSP"
        },
        {
          "name": "5",
          "layout": "BSP"
        }
      ]
    }
  ]
}
